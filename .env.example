# TrafficSim Environment Variables

# Java Backend Configuration (Optional - if using Java backend for intensive computations)
NEXT_PUBLIC_JAVA_BACKEND_URL=http://localhost:8080

# Deployment
NEXT_PUBLIC_APP_URL=https://traffic-sim.vercel.app

# Feature Flags
NEXT_PUBLIC_ENABLE_JAVA_BACKEND=false
NEXT_PUBLIC_ENABLE_EXPORTS=true

# Analytics (if using Vercel Analytics)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Optional: Custom logging
DEBUG=traffic-sim:*
